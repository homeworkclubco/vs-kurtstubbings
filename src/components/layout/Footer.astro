---
import socialIcons from "../../assets/socialIcons";
import Cluster from "./Cluster.astro";
import Container from "./Container.astro";
import Icon from "./Icon.astro";
import Section from "./Section.astro";
import Stack from "./Stack.astro";

// TODO: add your social links here
const socials: Record<string, string> = {};
---

<Section as="footer" colorScheme="dark" padding="xl">
  <Container>
    <Stack class="footer-inner" space="lg">
      <nav class="footer-nav">
        <Cluster as="ul" justify="center" spaceX="xl" spaceY="sm">
          <li><a href="/about">About</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
        </Cluster>
      </nav>

      {
        Object.keys(socials).length > 0 && (
          <Cluster class="socials" as="ul" justify="center" space="md">
            {Object.entries(socials).map(([name, url]) => (
              <li>
                <a
                  href={url}
                  aria-label={name}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon size="xl">
                    <Fragment set:html={socialIcons[name as keyof typeof socialIcons] ?? ""} />
                  </Icon>
                </a>
              </li>
            ))}
          </Cluster>
        )
      }

      <hr />

      <Cluster class="bottom xs:flex-col" justify="between">
        <p>
          &copy; {new Date().getFullYear()} Your Site. All rights reserved.
        </p>
      </Cluster>
    </Stack>
  </Container>
</Section>

<style>
  .footer-inner {
    text-align: center;

    hr {
      width: 100%;
      border: none;
      border-top: 1px solid var(--color-border);
    }
  }

  .footer-nav {
    a {
      font-family: var(--font-family-heading-alt);
      font-size: var(--font-size-2);
      font-weight: var(--font-weight-black);
      text-transform: uppercase;

      &:hover {
        color: var(--color-accent);
      }
    }
  }

  .socials {
    a {
      color: var(--color-foreground);
      display: flex;
      align-items: center;
      text-decoration: none;
      transition: all 0.3s var(--easing);

      &:hover {
        color: var(--color-accent);
      }
    }
  }

  .bottom {
    width: 100%;
    font-size: var(--font-size--1);
    color: var(--color-foreground-secondary);

    a {
      color: var(--color-foreground-secondary);
      text-decoration: none;
      transition: all 0.3s var(--easing);

      &:hover {
        color: var(--color-foreground);
      }
    }
  }
</style>
